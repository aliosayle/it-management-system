generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum MovementType {
  IN
  OUT
  ADJUST
  RETURN
  FOUND
  SCRAP
  LOSS
}

enum PurchaseDestination {
  STOCK
  PERSONNEL_BIN
  /** All lines go to the same site bin. */
  SITE_BIN
  /** Purchase has both stock and personal-bin lines, or multiple bin assignees. */
  MIXED
}

enum PurchaseStatus {
  PENDING
  COMPLETE
  CANCELLED
}

enum BinKind {
  PERSONNEL
  SITE
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  displayName    String
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  personnel      Personnel?
  purchases      Purchase[]
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
}

model Site {
  id                     String         @id @default(cuid())
  companyId              String
  company                Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                   String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  personnel              Personnel[]
  siteBinItems           SiteBinItem[]
  purchaseHeaderTargets  Purchase[]     @relation("PurchaseSiteBinSummary")
  purchaseLinesBinTarget PurchaseLine[] @relation("PurchaseLineSiteBinTarget")

  @@index([companyId])
}

/// People managed in IT (bins, sites, etc.). `user` is optional—only if they should log into this app.
model Personnel {
  id                      String             @id @default(cuid())
  siteId                  String
  site                    Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  userId                  String?            @unique
  user                    User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  /** When true, this person may be chosen as purchase authorizer (bon). */
  canAuthorizePurchases   Boolean            @default(false)
  /** When true, this person may be chosen as buyer (acheteur) on purchases. */
  isBuyer                 Boolean            @default(false)
  binItems                 PersonnelBinItem[]
  purchaseLinesBinTarget  PurchaseLine[]     @relation("PurchaseLineBinTarget")
  purchasesAuthorized     Purchase[]         @relation("PurchaseAuthorizer")
  purchasesBinTarget      Purchase[]         @relation("PurchaseBinTarget")
  purchasesBuyer          Purchase[]         @relation("PurchaseBuyer")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([siteId])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String     @unique @db.VarChar(512)
  email     String?    @db.VarChar(255)
  phone     String?    @db.VarChar(64)
  notes     String?    @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([name])
}

model Product {
  id                 String             @id @default(cuid())
  sku                String             @unique
  name               String
  /** User-defined grouping for filtering and reporting (e.g. IT hardware, consumables). */
  category           String             @default("") @db.VarChar(128)
  description        String?
  quantityOnHand     Decimal            @default(0) @db.Decimal(14, 4)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  stockMovements     StockMovement[]
  personnelBinItems  PersonnelBinItem[]
  siteBinItems       SiteBinItem[]
  purchaseLines      PurchaseLine[]
}

/// Personal catalog per personnel member (not warehouse stock).
model PersonnelBinItem {
  id          String    @id @default(cuid())
  personnelId String
  personnel   Personnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Decimal   @default(1) @db.Decimal(14, 4)
  note        String?   @db.Text
  kind        BinKind   @default(PERSONNEL)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([personnelId, productId])
  @@index([personnelId])
  @@index([productId])
}

/// Site-level bin (same semantics as personnel bin for purchases; not warehouse stock).
model SiteBinItem {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal  @default(1) @db.Decimal(14, 4)
  note      String?  @db.Text
  kind      BinKind  @default(SITE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, productId])
  @@index([siteId])
  @@index([productId])
}

model Purchase {
  id                      String              @id @default(cuid())
  destination             PurchaseDestination
  status                  PurchaseStatus      @default(PENDING)
  supplierId              String
  supplier                Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  authorizedByPersonnelId String
  authorizedBy            Personnel           @relation("PurchaseAuthorizer", fields: [authorizedByPersonnelId], references: [id])
  buyerPersonnelId        String
  buyerPersonnel          Personnel           @relation("PurchaseBuyer", fields: [buyerPersonnelId], references: [id], onDelete: Restrict)
  targetPersonnelId       String?
  targetPersonnel         Personnel?          @relation("PurchaseBinTarget", fields: [targetPersonnelId], references: [id], onDelete: SetNull)
  targetSiteId            String?
  targetSite              Site?               @relation("PurchaseSiteBinSummary", fields: [targetSiteId], references: [id], onDelete: SetNull)
  bonStoredPath           String              @db.VarChar(1024)
  bonOriginalName         String              @db.VarChar(512)
  notes                   String?             @db.Text
  createdByUserId         String
  createdBy               User                @relation(fields: [createdByUserId], references: [id])
  lines                   PurchaseLine[]
  stockMovements          StockMovement[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([authorizedByPersonnelId])
  @@index([buyerPersonnelId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseLine {
  id                  String               @id @default(cuid())
  purchaseId          String
  purchase            Purchase             @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId           String
  product             Product              @relation(fields: [productId], references: [id])
  quantity            Decimal              @db.Decimal(14, 4)
  unitPrice           Decimal              @db.Decimal(14, 4)
  lineIndex           Int                  @default(0)
  /** Where this line is received when the purchase is complete (not MIXED). */
  destination       PurchaseDestination
  targetPersonnelId String?
  targetPersonnel   Personnel?          @relation("PurchaseLineBinTarget", fields: [targetPersonnelId], references: [id], onDelete: SetNull)
  targetSiteId      String?
  targetSite        Site?               @relation("PurchaseLineSiteBinTarget", fields: [targetSiteId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
  @@index([targetPersonnelId])
  @@index([targetSiteId])
}

/// IN/RETURN/FOUND: units received. OUT/SCRAP/LOSS: units removed. ADJUST: `quantity` is the new on-hand level.
model StockMovement {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  type         MovementType
  quantity     Decimal      @db.Decimal(14, 4)
  balanceAfter Decimal      @db.Decimal(14, 4)
  note         String?      @db.Text
  purchaseId   String?
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([purchaseId])
}
