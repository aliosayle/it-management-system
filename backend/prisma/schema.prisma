generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum MovementType {
  IN
  OUT
  ADJUST
  RETURN
  FOUND
  SCRAP
  LOSS
}

enum PurchaseDestination {
  STOCK
  PERSONNEL_BIN
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  displayName    String
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  personnel      Personnel?
  purchases      Purchase[]
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
}

model Site {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  personnel Personnel[]

  @@index([companyId])
}

/// People managed in IT (bins, sites, etc.). `user` is optional—only if they should log into this app.
model Personnel {
  id                      String             @id @default(cuid())
  siteId                  String
  site                    Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  userId                  String?            @unique
  user                    User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  /** When true, this person may be chosen as purchase authorizer (bon). */
  canAuthorizePurchases   Boolean            @default(false)
  binItems                PersonnelBinItem[]
  purchasesAuthorized     Purchase[]         @relation("PurchaseAuthorizer")
  purchasesBinTarget      Purchase[]         @relation("PurchaseBinTarget")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([siteId])
}

model Product {
  id                 String             @id @default(cuid())
  sku                String             @unique
  name               String
  description        String?
  quantityOnHand     Decimal            @default(0) @db.Decimal(14, 4)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  stockMovements     StockMovement[]
  personnelBinItems  PersonnelBinItem[]
  purchaseLines      PurchaseLine[]
}

/// Personal catalog per personnel member (not warehouse stock).
model PersonnelBinItem {
  id          String    @id @default(cuid())
  personnelId String
  personnel   Personnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Decimal   @default(1) @db.Decimal(14, 4)
  note        String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([personnelId, productId])
  @@index([personnelId])
  @@index([productId])
}

model Purchase {
  id                      String              @id @default(cuid())
  destination             PurchaseDestination
  authorizedByPersonnelId String
  authorizedBy            Personnel           @relation("PurchaseAuthorizer", fields: [authorizedByPersonnelId], references: [id])
  targetPersonnelId     String?
  targetPersonnel         Personnel?          @relation("PurchaseBinTarget", fields: [targetPersonnelId], references: [id], onDelete: SetNull)
  bonStoredPath           String              @db.VarChar(1024)
  bonOriginalName         String              @db.VarChar(512)
  notes                   String?             @db.Text
  createdByUserId       String
  createdBy               User                @relation(fields: [createdByUserId], references: [id])
  lines                   PurchaseLine[]
  stockMovements        StockMovement[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([authorizedByPersonnelId])
  @@index([createdAt])
}

model PurchaseLine {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Decimal  @db.Decimal(14, 4)
  lineIndex  Int      @default(0)

  @@index([purchaseId])
  @@index([productId])
}

/// IN/RETURN/FOUND: units received. OUT/SCRAP/LOSS: units removed. ADJUST: `quantity` is the new on-hand level.
model StockMovement {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  type         MovementType
  quantity     Decimal      @db.Decimal(14, 4)
  balanceAfter Decimal      @db.Decimal(14, 4)
  note         String?      @db.Text
  purchaseId   String?
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([purchaseId])
}
