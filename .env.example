# Copy to .env in the repo root. Use your local MySQL (not Docker).
# Create database: CREATE DATABASE it_management CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

DATABASE_URL="mysql://root:'goldfish@2025'@localhost:3306/it_management"
JWT_SECRET="this-is-a-random-very-long-string-test-jwt-set"
PORT=3001
# Comma-separated if you use both localhost and a LAN URL (required for CORS when opening from another PC).
HOST=0.0.0.0
FRONTEND_ORIGIN="http://localhost:5173,http://YOUR_SERVER_LAN_IP:5173"

# Optional: absolute path for purchase receipt (bon) uploads. Default: backend/uploads/purchases
# PURCHASE_UPLOAD_DIR=
